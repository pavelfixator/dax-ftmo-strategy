# Kopíruj jako `.env` a vyplň. `.env` NEPUSHUJ do Gitu (viz .gitignore).

# === Python interpreter ===
# Absolutní cesta k python.exe (kvůli Windows MS-Store aliasu v PATH)
PYTHON_EXE=C:/Users/AOS Server/AppData/Local/Programs/Python/Python312/python.exe

# === GitHub ===
GITHUB_TOKEN=

# === Discord webhooks ===
DISCORD_WEBHOOK_SIGNALY=
DISCORD_WEBHOOK_JOURNAL=
DISCORD_WEBHOOK_BACKTEST=
DISCORD_WEBHOOK_MISTAKES=
DISCORD_WEBHOOK_ACCOUNT=
DISCORD_WEBHOOK_ALERTS=
DISCORD_WEBHOOK_DIVERGENCE=

# === MT5 (FTMO demo / Challenge) ===
MT5_LOGIN=
MT5_SERVER=
# MT5_PASSWORD NEUKLÁDAT — MT5 terminal si ho pamatuje sám

# === Email fallback ===
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# === Obsidian vault ===
OBSIDIAN_VAULT_PATH=C:/Users/AOS Server/trading-lab-DAX/DAX-FTMO-Strategy
